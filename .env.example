# ====================================================
#  큐이미지 스튜디오 — 환경변수
#  이 파일을 .env 로 복사해 채우세요. (.env 는 커밋되지 않음)
# ====================================================

# ── 팀 모드 (Supabase + Vercel) ─────────────────────
# 아래 4개를 채우면 "팀 모드"로 동작: 로그인 필요 + 서버 저장.
# (Vercel 에 배포할 땐 이 값들을 Vercel 프로젝트 환경변수에 등록하세요)

# 클라이언트 + 함수 공용 (VITE_ 접두사라 빌드 시 프론트에 포함됨 / anon 키는 공개돼도 안전)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# 서버(함수) 전용 비밀 — 절대 클라이언트에 노출 금지
OPENAI_API_KEY=sk-...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── 자체 호스팅(Express) 모드 ───────────────────────
# Supabase 없이 Express(server/index.js)로 키만 숨겨 돌릴 때.
# PORT=3000
# (이 모드로 프론트 빌드: npm run build:proxy)

# ── 직접 모드 ───────────────────────────────────────
# 위 값들을 모두 비우면 직접 모드(브라우저가 OpenAI 직접 호출, 키는 사용자 입력).
